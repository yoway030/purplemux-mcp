{
  "name": "purplemux-mcp",
  "version": "0.1.0",
  "description": "MCP server exposing the purplemux localhost HTTP API over stdio — terminal, browser, and agent-orchestration tools.",
  "type": "module",
  "bin": {
    "purplemux-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prebuild": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "smoke": "node test/smoke.mjs",
    "e2e": "node test/e2e.mjs",
    "unit": "node test/unit.mjs",
    "test": "npm run build && npm run unit && npm run smoke"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "@types/node": "^20.14.0"
  }
}
