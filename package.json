{
  "name": "purplemux-mcp",
  "version": "0.1.0",
  "description": "MCP server for the purplemux localhost HTTP API (16 tools over stdio).",
  "type": "module",
  "bin": {
    "purplemux-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "smoke": "node test/smoke.mjs",
    "e2e": "node test/e2e.mjs",
    "unit": "node test/unit.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "@types/node": "^20.14.0"
  }
}
